# NeonBeam OS — Environment Configuration
# ─────────────────────────────────────────
# Copy this file to .env before starting the service:
#   cp .env.example .env
#
# In DEVELOPMENT mode (Vite dev server) these values are read at runtime by
# the Node process and injected into the app via Vite's import.meta.env.
#
# In PRODUCTION mode (Dockerfile.prod / nginx) VITE_* values are BAKED INTO
# the compiled JavaScript bundle at build time.  They must be passed as Docker
# build args — changing .env after the build has no effect.


# ── Backend API URLs ─────────────────────────────────────────────────────────
#
# NeonBeam Core (hardware_comm) REST + WebSocket API.
# Development:  NeonBeam Core is running on the same host — use localhost.
# Production:   Replace with the Pi 4 hostname or IP.
VITE_COMM_API_URL=http://localhost:8000

# NeonBeam Lens (machine_vision) REST API.
# Development:  Lens is running on the same host — use localhost.
# Production:   Replace with the Pi 5 hostname or IP.
VITE_VISION_API_URL=http://localhost:8001

# ── Accessing from a mobile device on the same LAN ──────────────────────────
# If you load the app from a phone, 'localhost' won't resolve to your dev
# machine.  Set both URLs to your machine's LAN IP instead, e.g.:
# VITE_COMM_API_URL=http://192.168.1.50:8000
# VITE_VISION_API_URL=http://192.168.1.50:8001


# ── mDNS Sidecar ─────────────────────────────────────────────────────────────
#
# The sidecar must run NATIVELY on the host OS (not in Docker).
# Start it before running this container:
#   Windows:      .\discovery_sidecar\start_sidecar.ps1
#   Linux/macOS:  ./discovery_sidecar/start_sidecar.sh
#
# When running the frontend inside Docker, 'localhost' inside the container
# refers to the container's loopback — not the host.  Use host.docker.internal
# so the container can reach the sidecar running on the host OS.
#
# Docker Desktop (Windows / macOS):  host.docker.internal is resolved automatically.
# Linux Docker Engine:               host.docker.internal:host-gateway is added
#                                    via extra_hosts in docker-compose.yml.
DISCOVERY_SIDECAR_URL=http://host.docker.internal:3001

# When running Vite natively (npm run dev — no Docker):
# DISCOVERY_SIDECAR_URL=http://127.0.0.1:3001
